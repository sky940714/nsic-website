export default function AnnouncementSection() {
    return (
        <section className="py-24 bg-white">
            <div className="max-w-4xl mx-auto px-4 sm:px-6">
                <h2 className="text-2xl md:text-3xl font-bold text-slate-800 mb-12 text-center animate-on-scroll is-visible">諾科獎臺北峰會中立公告暨名義使用說明</h2>
                
                <div className="space-y-6 text-slate-600 leading-relaxed text-justify animate-on-scroll is-visible delay-100">
                    <p>諾科獎為以公益價值、教育推動與國際交流為核心之公益協會，秉持中立與獨立原則運作。諾科獎不為任何政黨、候選人或政治團體進行背書、動員或宣傳；亦不涉及任何宗教立場，且不以任何特定宗教觀點作為訴求。</p>
                    
                    <p>為確保諾科獎之永續發展與專業品質，諾科獎得於不影響理念獨立、內容自主及公共責任之前提下，進行必要之合作與資源支持安排。任何合作不得要求介入或影響諾科獎之核心治理、活動或課程內容、講者安排或其他關鍵決策。未經諾科獎事前之正式書面授權，任何個人或單位不得以諾科獎名義、名稱、標誌或相關識別，進行對外宣傳、合作聲稱、活動舉辦、商品販售、募款，或任何足以使第三人誤認、混淆與諾科獎具有合作、授權或關聯關係之行為。媒體報導、學術引用或其他合理描述，如未造成混淆或誤導者，不在此限。</p>
                    
                    <p>凡涉及誤用、擅用或可能造成混淆、誤導之情形，諾科獎得要求立即停止使用、更正、移除相關內容，並保留依法採取必要措施之權利。</p>
                    
